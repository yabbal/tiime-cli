{
  "name": "tiime-cli",
  "version": "2.0.2",
  "description": "CLI for Tiime accounting",
  "type": "module",
  "bin": {
    "tiime": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build",
    "release": "changeset publish"
  },
  "keywords": [
    "tiime",
    "accounting",
    "cli",
    "typescript",
    "france",
    "comptabilite",
    "factures",
    "invoices"
  ],
  "author": "yabbal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yabbal/tiime.git"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "homepage": "https://github.com/yabbal/tiime#readme",
  "bugs": {
    "url": "https://github.com/yabbal/tiime/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "citty": "^0.2.1",
    "cli-table3": "^0.6.5",
    "consola": "^3.4.2",
    "pathe": "^2.0.3",
    "tiime-sdk": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.3.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
