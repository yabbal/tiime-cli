{
  "name": "tiime-sdk",
  "version": "2.0.0",
  "description": "TypeScript SDK for Tiime accounting API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build",
    "release": "changeset publish"
  },
  "keywords": [
    "tiime",
    "accounting",
    "sdk",
    "typescript",
    "france",
    "comptabilite",
    "api-client"
  ],
  "author": "yabbal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yabbal/tiime-cli.git",
    "directory": "packages/tiime-sdk"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "homepage": "https://github.com/yabbal/tiime-cli#readme",
  "bugs": {
    "url": "https://github.com/yabbal/tiime-cli/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ofetch": "^1.5.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.3.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
