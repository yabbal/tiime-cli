{
  "name": "tiime-cli",
  "version": "1.0.0",
  "description": "CLI & SDK for Tiime accounting",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tiime": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "tiime",
    "accounting",
    "cli"
  ],
  "author": "Youness Abbal",
  "license": "MIT",
  "packageManager": "pnpm@10.30.2",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "citty": "^0.2.1",
    "cli-table3": "^0.6.5",
    "consola": "^3.4.2",
    "ofetch": "^1.5.1",
    "pathe": "^2.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.3.5",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
